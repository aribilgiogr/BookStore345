@using Core.Concrete.DTOs
@model IEnumerable<BookListItemDto>
@{
    ViewData["Title"] = "Home Page";
}

<section class="book-list-section py-5">
    <div class="container">
        <div class="row mb-4">
            <div class="col-12">
                <h2 class="fw-bold mb-0">Tüm Kitaplar</h2>
                <p class="text-muted">Aradığınız tüm eserleri bu kategoride bulabilirsiniz.</p>
            </div>
        </div>

        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-4">
            @foreach (var book in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">

                        @if (!string.IsNullOrEmpty(book.CoverImagePath))
                        {
                            <img src="@book.CoverImagePath" class="card-img-top object-fit-cover" alt="@book.Title">
                        }
                        else
                        {
                            <div class="card-img-top d-flex align-items-center justify-content-center bg-light text-secondary" style="height: 300px;">
                                <small>Görsel Bulunamadı</small>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">

                            <div class="d-flex flex-wrap align-items-start mb-2">
                                @foreach (var g in book.Genre.Split('|'))
                                {
                                    <span class="badge bg-secondary me-3 mb-2">@g</span>
                                }
                            </div>
                            <div class="d-flex align-items-start mb-2">
                                @if (book.InStock)
                                {
                                    <span class="badge bg-success">Stokta</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Tükendi</span>
                                }
                            </div>
                            <a asp-action="details" asp-controller="home" asp-route-id="@book.Id">
                                <h5 class="card-title text-truncate" title="@book.Title">@book.Title</h5>
                            </a>
                            <p class="card-text text-muted small mb-1">
                                <strong>Yazar:</strong> @book.AuthorName
                            </p>
                            <p class="card-text text-muted small mb-3">
                                <strong>Yayınevi:</strong> @book.PublisherName
                            </p>

                            <div class="mt-auto">
                                <hr class="text-muted" />
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fs-5 fw-bold text-dark">@book.Price.ToString("C2")</span>

                                    @if (book.InStock)
                                    {
                                        <a href="#" class="btn btn-outline-primary btn-sm">Sepete Ekle</a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-secondary btn-sm" disabled>Tükendi</button>
                                    }
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
